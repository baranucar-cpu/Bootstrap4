<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Gaming Nexus Lounge</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.1.3/dist/css/bootstrap.min.css">
</head>
<body>

<div class="container">

    <!-- navbar -->
    <nav class="navbar sticky-top navbar-expand-lg bg-dark">
        <div class="container-fluid">
            <div class="collapse navbar-collpase"> <!-- small typo: collpase -->
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item active">
                        <a class="nav-link text-light" href="#about">About</a>
                    </li>
                    <li class="nav-item active">
                        <a class="nav-link text-light" href="#games">Games</a>
                    </li>
                    <li class="nav-item active">
                        <a class="nav-link text-light" href="#events">Events</a>
                    </li>
                </ul>
                <form class="d-flex">
                    <input class="form-control mr-2" type="search" placeholder="Search">
                    <button class="btn btn-primary text-light" type="submit">Serach</button> <!-- typo: Serach -->
                </form>
            </div>
        </div>
    </nav>
    <!-- /navbar -->

    <!-- title -->
    <div class="jumbotron jumbotron-fluid bg-dark text-center">
        <div class="container">
            <h1 class="display-4 text-light">Gaming Nexus Lounge</h1>
            <p class="lead text-light">Play. Compete. Conect.</p> <!-- typo: Conect -->
        </div>
    </div>
    <!-- /title -->

    <!-- About section -->
    <div class="container">
        <div class="row align-items-start">
            <div class="col">
                <img class="img-fluid" src="./img/lounge.jpg" alt="Gaming Lounge">
            </div>
            <div class="col">
                <h3 id="about">About Us :</h3> <!-- extra space before colon -->
                <p>Located in downtown Toronto, Gaming Nexus Lounge is the ultimate destination for gamers.</p>
                <p>We offer high-end PCs, next-gen consoles, VR stations and a premium gaming enviroment.</p> <!-- typo: enviroment -->
                <p>Whether you're a casual player or a competitive esports fan, we’ve got something for you.</p>
                <p>Relax in our ergonomic gaming chairs and enjoy ultra-fast fiber internet</p> <!-- missing period -->
            </div>
            <div class="col">
                <h3>Featured Games:</h3>
                <ul class="list-group">
                    <li class="list-group-item"><a class="nav-link active" href="#">Valorant</a></li>
                    <li class="list-group-item"><a class="nav-link" href="#">Fortnite</a></li>
                    <li class="list-group-item"><a class="nav-link" href="#">League of Legends</a></li>
                </ul>
            </div>
        </div>
    </div>
    <!-- /About section -->

    <!-- Games section -->
    <div class="container my-5">
        <h3 id="games">Game Stations</h3> <!-- missing colon -->
        <div class="row">

            <div class="col-sm-4">
                <div class="card h-100">
                    <img class="card-img-top" src="./img/valorant.jpg" alt="Valorant">
                    <div class="card-body">
                        <h5 class="card-title">Valorant</h5>
                        <p class="card-text">Tactical 5v5 shooter with intense competitive gameplay</p> <!-- missing period -->
                        <span class="badge badge-info">Available 24/7</span>
                    </div>
                </div>
            </div>

            <div class="col-sm-4">
                <div class="card h-100">
                    <img class="card-img-top" src="./img/fortnite.jpg" alt="Fortnite">
                    <div class="card-body">
                        <h5 class="card-title">Fortnite</h5>
                        <p class="card-text">Battle royale action with constant updates and events.</p>
                        <span class="badge badge-info">Available 24/7</span>
                    </div>
                </div>
            </div>

            <div class="col-sm-4">
                <div class="card h-100">
                    <img class="card-img-top" src="./img/lol.jpg" alt="League of Legends">
                    <div class="card-body">
                        <h5 class="card-title">League of Legends</h5>
                        <p class="card-text">The world’s most popular MOBA with ranked and casual modes.</p>
                        <span class="badge badge-info">Available 24/7</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <!-- /Games section -->

    <!-- Events -->
    <div class="text-center">
        <form id="events">
            <h1 class="text-primary my-5">Join Our Weekly Tournamets!</h1> <!-- typo: Tournamets -->
            <div class="mb-3">
                <input type="email" class="form-control" placeholder="Enter your email ">
            </div>
            <button type="submit" class="btn btn-primary">Sign Up</button>
        </form>
    </div>
    <!-- /Events -->

    <!-- footer -->
    <div class="container my-5">
        <ul class="nav">
            <li class="nav-item"><small><a class="nav-link active" href="#">Membership</a></small></li>
            <li class="nav-item"><small><a class="nav-link" href="#">Support</a></small></li>
            <li class="nav-item"><small><a class="nav-link" href="#">contact@gamingnexus.com</a></small></li>
            <li class="nav-item"><small><a class="nav-link">&copy;2024 Gaming Nexus Lounge</a></small></li>
        </ul>
    </div>
    <!-- /footer -->

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.1.3/dist/js/bootstrap.min.js"></script>
</body>
</html>
